{
  "name": "codebase-analysis",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "dev:server": "pnpm --filter @codebase-analysis/server dev"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "tree-sitter",
      "tree-sitter-java",
      "tree-sitter-javascript",
      "tree-sitter-typescript"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.0"
  }
}
