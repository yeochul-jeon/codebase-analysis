# Upload authentication token (ADR-007).
# Used by CI pipelines and `analyze push` CLI.
# Copy this file to docker/.env and set a strong random value.
ANALYZE_UPLOAD_TOKEN=change-me-to-a-strong-random-string

# ── Variant A (default) ───────────────────────────────────────────────────────
# DB_BACKEND=sqlite
# STORAGE_BACKEND=fs

# ── Variant B (PostgreSQL + S3/MinIO) ─────────────────────────────────────────
# Activate with: docker compose --profile variant-b up
# Set these variables in docker/.env to switch to Variant B.
#
# DB_BACKEND=pg
# STORAGE_BACKEND=s3
#
# PostgreSQL (matches the postgres service below)
# PG_URL=postgres://ca:ca@postgres:5432/ca
#
# S3 / MinIO (matches the minio service below)
# S3_BUCKET=ca-blobs
# S3_REGION=us-east-1
# S3_ENDPOINT=http://minio:9000
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin
# S3_FORCE_PATH_STYLE=1
